;;; -*- mode : lisp -*-
(:author "Vladimir Dikan"
 :deploy-dir "deploy/"
 :domain "https://www.ivorysiegetower.com"
 :routing ((:post           "posts/~a")
           (:tag-index      "tag/~a")
           (:month-index    "date/~a")
           (:numeric-index  "~d")
           (:feed           "~a.xml")
           (:tag-feed       "tag/~a.xml"))
 :title "Ivory Siege Tower"
 :theme "tower"

 ;; Optional information
 :excerpt-sep "<!--more-->"
 :feeds ("en" "ru")
 :plugins ((mathjax)
           (sitemap)
           (static-pages)
           (pygments)
           (3bmd-youtube)
           ;; deployment plugins
           ;; deployment to github pages
           (gh-pages :url "git@github.com:vdikan/siegetower.git"
                     :branch "gh-pages"
                     :remote "origin"
                     :cname t))
 :sitenav ();; (:url "http://github.com/vdikan" :name "Code")
 :staging-dir "/tmp/coleslaw/")
